@startuml Partilha de Listas - User B (Partilhado)

title Utilizador Partilhado (User B) consulta tarefas

actor "Utilizador Partilhado (User B)" as Shared

participant "Controller" as C
participant "Service" as S
participant "Repository" as R
database "PostgreSQL" as DB

Shared -> C : GET /todo/1/tasks
C -> S : getTodoList(1)
S -> R : findById(1)
R -> DB : SELECT * FROM lists WHERE id=1
DB --> R : {id=1, owner_id=1}
R --> S : TodoList
S --> C : TodoList(ownerId=1)
C -> C : ownerId(1) != userId(2)\nverificar partilha...
C -> R : isShared(listId=1, userId=2)
R -> DB : SELECT * FROM list_shares\nWHERE list_id=1 AND user_id=2
DB --> R : existe
R --> C : true
C -> S : getAllTodoItemsByListId(1)
S -> R : findAllByListId(1)
R -> DB : SELECT * FROM todos\nWHERE list_id=1
DB --> R : [Todo, Todo, ...]
R --> S : List<Todo>
S --> C : List<Todo>
C --> Shared : 200 OK\n[{description:"Bread"}, ...]

@enduml
